# Production Environment Variables
# Copy this file to .env.prod and fill in the values

# Database
POSTGRES_USER=boardy
POSTGRES_PASSWORD=<GENERATE: openssl rand -hex 32>
POSTGRES_DB=boardy

# Application
SECRET_KEY=<GENERATE: openssl rand -hex 32>
APP_URL=https://your-domain.com
MCP_SERVER_URL=https://your-domain.com/mcp

# Cloudflare R2 (Phase 3 - file storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
